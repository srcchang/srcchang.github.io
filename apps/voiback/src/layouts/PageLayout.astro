---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';

import { headerData, footerData } from '~/navigation';

import type { MetaData } from '~/types';

import { getUI, type Locale } from '~/i18n/ui';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  metadata?: MetaData;
}

const { metadata } = Astro.props;
const locale = (Astro.currentLocale || 'zh-TW') as Locale;
const t = getUI(locale);

const headerLinks = [
  { text: t['nav.features'], href: getPermalink('/#features') },
  { text: t['nav.faq'], href: getPermalink('/faq') },
];

const footerSecondaryLinks = [
  { text: t['footer.privacy'], href: getPermalink('/privacy') },
  { text: t['footer.terms'], href: getPermalink('/terms') },
];
---

<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header {...headerData} links={headerLinks} isSticky locale={locale} />
  </Fragment>
  <main>
    <slot />
  </main>
  <Fragment slot="footer">
    <Footer {...footerData} secondaryLinks={footerSecondaryLinks} locale={locale} />
  </Fragment>
</Layout>
