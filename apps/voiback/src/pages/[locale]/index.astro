---
export const getStaticPaths = () => {
  const locales = ['zh-TW', 'zh-CN', 'en', 'ja', 'ko'] as const;
  return locales.map((locale) => ({ params: { locale } }));
};

import PageLayout from '~/layouts/PageLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import StoreButtons from '~/components/StoreButtons.astro';

import { getUI, type Locale } from '~/i18n/ui';
import { getLocalePermalink } from '~/utils/permalinks';

const locale = (Astro.currentLocale || 'zh-TW') as Locale;
const t = getUI(locale);

const metadata = {
  title: 'VOIBACK',
};
---

<PageLayout metadata={metadata}>
  <Fragment slot="announcement"></Fragment>

  <!-- Hero ******************* -->
  <Hero2
    tagline={t['hero.tagline']}
  >
    <Fragment slot="title">
      <Fragment set:html={t['hero.title']} />
    </Fragment>

    <Fragment slot="subtitle">
      {t['hero.subtitle']}
    </Fragment>

    <Fragment slot="image">
      <img src="/voiback/hero-placeholder.svg" alt="VOIBACK App" class="mx-auto rounded-md w-full" />
    </Fragment>
    <StoreButtons slot="actions" locale={locale} />
  </Hero2>

  <!-- How It Works ************ -->
  <Steps
    title={t['how.title']}
    tagline=""
    isReversed={false}
    items={[
      {
        title: t['how.step1.title'],
        description: t['how.step1.desc'],
        icon: 'tabler:microphone',
      },
      {
        title: t['how.step2.title'],
        description: t['how.step2.desc'],
        icon: 'tabler:player-play',
      },
      {
        title: t['how.step3.title'],
        description: t['how.step3.desc'],
        icon: 'tabler:stars',
      },
    ]}
  />

  <!-- Features **************** -->
  <Features3
    id="features"
    title={t['features.title']}
    columns={2}
    items={[
      {
        title: t['features.sentences.title'],
        description: t['features.sentences.desc'],
        icon: 'tabler:books',
      },
      {
        title: t['features.multiplayer.title'],
        description: t['features.multiplayer.desc'],
        icon: 'tabler:users',
      },
      {
        title: t['features.waveform.title'],
        description: t['features.waveform.desc'],
        icon: 'tabler:wave-sine',
      },
      {
        title: t['features.share.title'],
        description: t['features.share.desc'],
        icon: 'tabler:share',
      },
    ]}
  />

  <!-- FAQ Preview ************* -->
  <FAQs
    title={t['faq.title']}
    columns={1}
    items={[
      {
        title: t['faq.q1.title'],
        description: t['faq.q1.desc'],
      },
      {
        title: t['faq.q2.title'],
        description: t['faq.q2.desc'],
      },
      {
        title: t['faq.q3.title'],
        description: t['faq.q3.desc'],
      },
      {
        title: t['faq.q4.title'],
        description: t['faq.q4.desc'],
      },
    ]}
  />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 -mt-6 mb-4 text-center">
    <a
      href={getLocalePermalink('/faq', locale)}
      class="inline-flex items-center gap-1 cursor-pointer text-primary font-medium hover:underline transition-colors duration-150"
    >
      {t['faq.more']}
      <span aria-hidden="true">→</span>
    </a>
  </div>

  <!-- CTA ********************* -->
  <CallToAction
    title={t['cta.title']}
    subtitle={t['cta.subtitle']}
  >
    <StoreButtons slot="actions" locale={locale} class="flex flex-wrap gap-4 justify-center" />
  </CallToAction>
</PageLayout>
