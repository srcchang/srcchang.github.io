---
import Layout from '~/layouts/Layout.astro';
import { getHomePermalink } from '~/utils/permalinks';

const locales = ['zh-TW', 'zh-CN', 'en', 'ja', 'ko'];
const labels: Record<string, string> = {
  'zh-TW': '繁體中文',
  'zh-CN': '简体中文',
  en: 'English',
  ja: '日本語',
  ko: '한국어',
};

const title = `Error 404`;
---

<Layout metadata={{ title }}>
  <section class="flex items-center h-full p-16">
    <div class="container flex flex-col items-center justify-center px-5 mx-auto my-8">
      <div class="max-w-md text-center">
        <h2 class="mb-8 font-bold text-9xl">
          <span class="sr-only">Error</span>
          <span class="text-primary">404</span>
        </h2>
        <p class="text-3xl font-semibold md:text-3xl">Sorry, we couldn't find this page.</p>
        <p class="mt-4 mb-8 text-lg text-muted dark:text-slate-400">
          Please select your language to continue:
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          {locales.map((code) => (
            <a
              href={`/voiback/${code}/`}
              class="px-4 py-2 text-sm rounded-lg border border-gray-700 hover:border-primary hover:text-primary transition-colors"
            >
              {labels[code]}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
