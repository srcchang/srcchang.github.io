---
import BaseLayout from '../layouts/BaseLayout.astro';
import { locales, localeLabels, withBase } from '../i18n/config';
---

<BaseLayout title="Error 404 — VOIBACK" description="Page not found" locale="zh-TW" currentPath="/404" noindex>
  <section class="flex items-center min-h-screen p-16">
    <div class="container flex flex-col items-center justify-center px-5 mx-auto">
      <div class="max-w-md text-center">
        <h1 class="mb-8 font-bold text-9xl font-heading">
          <span class="sr-only">Error</span>
          <span class="text-primary">404</span>
        </h1>
        <p class="text-3xl font-semibold">Sorry, we couldn't find this page.</p>
        <p class="mt-4 mb-8 text-lg text-muted">Please select your language to continue:</p>
        <div class="flex flex-wrap justify-center gap-3">
          {
            locales.map((code) => (
              <a
                href={withBase(`/${code}/`)}
                class="px-4 py-2 text-sm rounded-lg border border-gray-700 hover:border-primary hover:text-primary transition-colors no-underline"
              >
                {localeLabels[code]}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
