---
import Logo from '~/components/Logo.astro';
import LanguageSwitcher from '~/components/LanguageSwitcher.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';

import { trimSlash } from '~/utils/permalinks';
import type { CallToAction } from '~/types';

interface MenuLink {
  text?: string;
  href?: string;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  locale?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  locale = 'zh-TW',
} = Astro.props;

// Normalize path by stripping locale segment for link matching
const rawPath = '/' + trimSlash(Astro.url.pathname);
const knownLocales = ['zh-TW', 'zh-CN', 'en', 'ja', 'ko'];
const segments = rawPath.split('/').filter(Boolean);
const localeIdx = segments.findIndex(s => knownLocales.includes(s));
const currentPath = localeIdx >= 0
  ? '/' + segments.filter((_, i) => i !== localeIdx).join('/')
  : rawPath;

const isActive = (href: string): boolean => {
  if (!href) return false;
  const hrefClean = href.split('#')[0].replace(/\/$/, '') || '/';
  const pathClean = currentPath.replace(/\/$/, '') || '/';
  return hrefClean === pathClean;
};
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky, dark: isDark },
    'top-0 z-40 flex-none mx-auto w-full border-b border-gray-50/0 transition-[opacity] ease-in-out',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="absolute inset-0"></div>
  <div
    class:list={[
      'relative text-default py-3 px-3 md:px-6 mx-auto w-full flex items-center justify-between',
      { 'max-w-7xl': !isFullWidth },
    ]}
  >
    <Logo locale={locale} />

    <nav
      class="items-center w-full md:w-auto hidden md:flex md:mx-5 text-default overflow-y-auto overflow-x-hidden md:overflow-visible"
      aria-label="Main navigation"
    >
      <ul class="flex flex-col md:flex-row md:self-center w-full md:w-auto text-lg md:text-[0.9375rem] tracking-[0.01rem] font-medium gap-1 items-center justify-center pt-8 md:pt-0">
        {
          links.map(({ text, href }) => (
            <li class="w-full text-center md:w-auto">
              <a
                class:list={[
                  'hover:text-primary transition-colors duration-150 px-4 py-3 md:py-2 flex items-center justify-center whitespace-nowrap rounded-lg',
                  { 'aw-link-active': isActive(href) },
                ]}
                href={href}
              >
                {text}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-3">
      <LanguageSwitcher locale={locale} />
      <div class="flex items-center md:hidden">
        <ToggleMenu />
      </div>
    </div>
  </div>
</header>
