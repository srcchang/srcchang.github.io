---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Chakra Petch';

    --aw-color-primary: rgb(0 245 160);
    --aw-color-secondary: rgb(139 92 246);
    --aw-color-accent: rgb(255 77 109);

    --aw-color-text-heading: rgb(230 233 242);
    --aw-color-text-default: rgb(230 233 242);
    --aw-color-text-muted: rgb(138 138 166);
    --aw-color-bg-page: rgb(10 11 20);
    --aw-color-bg-page-dark: rgb(10 11 20);

    ::selection {
      background-color: rgb(0 245 160 / 30%);
    }
  }


</style>
