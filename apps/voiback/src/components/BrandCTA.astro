---
import { type Locale } from '../i18n/config';
import { getTranslations, t } from '../i18n/translations';
import StoreButtons from './StoreButtons.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = getTranslations(locale);
---

<section class="relative scroll-mt-[72px]">
  <div class="relative mx-auto max-w-6xl px-4 md:px-6 py-12 md:py-16 lg:py-20 text-default">
    <div
      class="max-w-3xl mx-auto text-center p-6 md:p-8 rounded-2xl bg-white/[0.04] border border-primary/25 shadow-xl shadow-primary/5"
      data-reveal
    >
      <h2 class="text-4xl font-bold tracking-tighter mb-4 font-heading">{t(tr, 'cta.title')}</h2>
      <p class="text-xl text-muted">{t(tr, 'cta.subtitle')}</p>
      <div class="max-w-xs sm:max-w-md m-auto flex flex-col sm:flex-row sm:justify-center gap-4 mt-6">
        <StoreButtons locale={locale} class="flex flex-col sm:flex-row gap-4 justify-center w-full" />
      </div>
    </div>
  </div>
</section>
