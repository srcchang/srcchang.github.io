---
import { type Locale } from '../i18n/config';
import { getTranslations, t } from '../i18n/translations';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from './Nav.astro';
import FAQ from './FAQ.astro';
import BrandCTA from './BrandCTA.astro';
import Footer from './Footer.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = getTranslations(locale);
const currentPath = `/${locale}/faq`;
---

<BaseLayout
  title={`${t(tr, 'faq.page.title')} — ${t(tr, 'meta.brand')}`}
  description={t(tr, 'meta.description')}
  locale={locale}
  currentPath={currentPath}
>
  <Nav locale={locale} currentPath={currentPath} />
  <div class="pt-16">
    <FAQ locale={locale} count={5} />
  </div>
  <BrandCTA locale={locale} />
  <Footer locale={locale} currentPath={currentPath} />
</BaseLayout>
