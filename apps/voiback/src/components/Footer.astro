---
import { localeLabels, locales, stripLocale, withBase, type Locale } from '../i18n/config';
import { getTranslations, t } from '../i18n/translations';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const tr = getTranslations(locale);
const basePath = stripLocale(currentPath);

const secondaryLinks = [
  { text: t(tr, 'footer.privacy'), href: withBase(`/${locale}/privacy`) },
  { text: t(tr, 'footer.terms'), href: withBase(`/${locale}/terms`) },
];
---

<footer data-embed-hide class="relative border-t border-gray-800 mt-12">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col md:flex-row items-center justify-between py-8 gap-4">
      <Logo locale={locale} />

      <div class="flex items-center gap-4 text-sm text-muted">
        {
          secondaryLinks.map(({ text, href }, index) => (
            <>
              {index !== 0 && <span class="text-gray-600">·</span>}
              <a class="text-muted hover:text-primary transition-colors duration-150 no-underline" href={href}>
                {text}
              </a>
            </>
          ))
        }
      </div>

      <div class="flex flex-wrap gap-2 justify-center">
        {
          locales.map((l) => (
            <a
              href={withBase(`/${l}${basePath}`)}
              class:list={[
                'text-xs px-2 py-1 rounded-md border no-underline transition-colors',
                l === locale
                  ? 'border-primary text-primary'
                  : 'border-gray-700 text-muted hover:text-default hover:border-gray-500',
              ]}
            >
              {localeLabels[l]}
            </a>
          ))
        }
      </div>
    </div>

    <div class="py-4 border-t border-gray-800 text-center text-xs text-muted">VOIBACK</div>
  </div>
</footer>
