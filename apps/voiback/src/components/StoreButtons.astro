---
import { type Locale } from '../i18n/config';
import { getTranslations, t } from '../i18n/translations';

export interface Props {
  locale?: Locale;
  class?: string;
}

const { locale = 'zh-TW', class: className = 'flex flex-wrap gap-4' } = Astro.props;
const tr = getTranslations(locale);

const stores = [
  { href: t(tr, 'store.appstore'), label: t(tr, 'hero.cta.appstore'), variant: 'primary' as const },
  { href: t(tr, 'store.googleplay'), label: t(tr, 'hero.cta.googleplay'), variant: 'secondary' as const },
];

// 商店連結尚未提供（佔位 '#'、空字串或 t() 回傳 key 本身）時，以禁用的「即將推出」狀態呈現，避免死連結。
const isPlaceholder = (href: string) => !href || href === '#' || href.startsWith('store.');
---

<div class={className}>
  {
    stores.map(({ href, label, variant }) =>
      isPlaceholder(href) ? (
        <span
          class:list={[
            variant === 'primary' ? 'btn-primary' : 'btn-secondary',
            'opacity-60 cursor-not-allowed pointer-events-none',
          ]}
          role="button"
          aria-disabled="true"
          title={t(tr, 'cta.coming')}
        >
          {label} · {t(tr, 'cta.coming')}
        </span>
      ) : (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class={variant === 'primary' ? 'btn-primary' : 'btn-secondary'}
        >
          {label}
        </a>
      )
    )
  }
</div>
