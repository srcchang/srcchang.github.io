---
import { getTranslations, t } from '../i18n/translations';
import type { Locale } from '../i18n/config';
import VehicleGlow from './VehicleGlow.astro';
import DownloadCTA from './DownloadCTA.astro';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const tr = getTranslations(locale as Locale);
---

<section
  class="relative overflow-hidden bg-bg-muted px-4 py-20 sm:px-6 lg:px-8"
  data-reveal
>
  <!-- Vehicle glow decorations -->
  <VehicleGlow
    vehicle="car"
    position="absolute top-0 left-0 -translate-x-1/4 -translate-y-1/4"
    size="w-[400px]"
  />
  <VehicleGlow
    vehicle="moto"
    position="absolute bottom-0 right-0 translate-x-1/4 translate-y-1/4"
    size="w-[360px]"
  />

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-2xl text-center">
    <!-- Brand title -->
    <h2 class="text-2xl font-bold text-text-primary sm:text-3xl">
      {t(tr, 'brand.title')}
    </h2>

    <!-- Brand description -->
    <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-text-secondary">
      {t(tr, 'brand.description')}
    </p>

    <!-- CTA heading with gradient -->
    <p class="mt-10 bg-gradient-to-r from-car to-moto bg-clip-text text-3xl font-bold text-transparent sm:text-4xl">
      {t(tr, 'brand.cta')}
    </p>

    <!-- Download buttons -->
    <div class="mt-6">
      <DownloadCTA locale={locale} size="lg" />
    </div>
  </div>
</section>
