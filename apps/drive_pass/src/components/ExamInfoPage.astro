---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import DownloadCTA from './DownloadCTA.astro';
import Icon from './Icon.astro';
import { getTranslations, t } from '../i18n/translations';
import type { Locale } from '../i18n/config';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const tr = getTranslations(locale as Locale);
const translations = tr as Record<string, any>;
const checklistItems: string[] = translations.examInfo?.checklist?.items ?? [];

const pageTitle = t(tr, 'examInfo.pageTitle');
const pageSubtitle = t(tr, 'examInfo.pageSubtitle');

interface ExamSection {
  title: string;
  questionCount: string;
  timeLimit: string;
  passingScore: string;
  scoring: string;
  types: string;
}

const examRowKeys = ['questionCount', 'timeLimit', 'passingScore', 'scoring', 'types'] as const;

const examCards = [
  {
    section: translations.examInfo?.carSection as ExamSection,
    variant: 'car' as const,
    border: 'border-orange-200 dark:border-orange-900',
    iconBg: 'bg-orange-50 dark:bg-orange-950',
    accent: 'text-car',
    accentHover: 'text-car hover:text-car-deep',
    icon: 'car',
    href: `/${locale}/car`,
    ctaKey: 'examInfo.carCta',
  },
  {
    section: translations.examInfo?.motoSection as ExamSection,
    variant: 'moto' as const,
    border: 'border-purple-200 dark:border-purple-900',
    iconBg: 'bg-purple-50 dark:bg-purple-950',
    accent: 'text-moto',
    accentHover: 'text-moto hover:text-moto-deep',
    icon: 'motorcycle',
    href: `/${locale}/moto`,
    ctaKey: 'examInfo.motoCta',
  },
];
---
<BaseLayout
  title={`${pageTitle} — Drive Pass`}
  description={pageSubtitle}
  locale={locale}
  currentPath="/exam-info"
>
  <Nav locale={locale} currentPath="/exam-info" />

  <!-- Page Header -->
  <section class="bg-bg-surface px-4 pb-12 pt-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-3xl font-bold text-text-primary sm:text-4xl">
        {pageTitle}
      </h1>
      <p class="mt-3 text-lg text-text-secondary">
        {pageSubtitle}
      </p>
    </div>
  </section>

  <!-- Exam Rules Cards -->
  <section class="border-t border-border-subtle bg-bg-primary px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="grid gap-8 md:grid-cols-2">
        {examCards.map((card) => card.section && (
          <div class:list={['rounded-2xl border bg-bg-surface p-6', card.border]} data-reveal>
            <div class="mb-4 flex items-center gap-3">
              <div class:list={['flex h-10 w-10 items-center justify-center rounded-xl', card.iconBg, card.accent]}>
                <Icon name={card.icon} size="22" />
              </div>
              <h2 class="text-xl font-bold text-text-primary">{card.section.title}</h2>
            </div>
            <dl class="space-y-3">
              {examRowKeys.map((key) => (
                <div class="flex items-start justify-between gap-4 border-b border-border-subtle pb-3 last:border-0">
                  <dt class="text-sm font-medium text-text-secondary">{t(tr, `common.examLabels.${key}`)}</dt>
                  <dd class="text-right text-sm font-semibold text-text-primary">{card.section[key]}</dd>
                </div>
              ))}
            </dl>
            <a
              href={card.href}
              class:list={['mt-5 inline-block text-sm font-semibold transition-colors', card.accentHover]}
            >
              {t(tr, card.ctaKey)}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Practical Checklist -->
  <section class="border-t border-border-subtle bg-bg-surface px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl" data-reveal>
      <h2 class="mb-6 text-center text-xl font-bold text-text-primary sm:text-2xl">
        {t(tr, 'examInfo.checklist.title')}
      </h2>
      <ul class="space-y-3" aria-label={t(tr, 'examInfo.checklist.title')}>
        {checklistItems.map((item) => (
          <li class="flex items-center gap-3 rounded-xl border border-border-subtle bg-bg-primary px-5 py-3.5">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-green-100 text-green-600 dark:bg-green-950 dark:text-green-400">
              <Icon name="check" size="14" />
            </span>
            <span class="text-sm font-medium text-text-primary">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="relative overflow-hidden bg-bg-muted px-4 py-16 sm:px-6 lg:px-8" data-reveal>
    <div class="relative z-10 mx-auto max-w-xl text-center">
      <p class="bg-gradient-to-r from-car to-moto bg-clip-text text-2xl font-bold text-transparent sm:text-3xl">
        {t(tr, 'examInfo.cta')}
      </p>
      <div class="mt-6">
        <DownloadCTA locale={locale} size="lg" />
      </div>
    </div>
  </section>

  <Footer locale={locale} />
</BaseLayout>
