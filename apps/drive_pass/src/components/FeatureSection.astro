---
import Icon from './Icon.astro';

interface Props {
  icon: string;
  title: string;
  description: string;
  reversed?: boolean;
}

const { icon, title, description, reversed = false } = Astro.props;
---

<div
  class={`flex flex-col gap-8 md:flex-row md:items-center md:gap-12 ${reversed ? 'md:flex-row-reverse' : ''}`}
  data-reveal
>
  <!-- Icon side -->
  <div class="flex shrink-0 items-center justify-center md:w-2/5">
    <div class="flex h-28 w-28 items-center justify-center rounded-3xl bg-gradient-to-br from-bg-muted to-bg-surface shadow-sm ring-1 ring-border-subtle sm:h-36 sm:w-36">
      <Icon name={icon} size="48" class="text-text-secondary sm:h-14 sm:w-14" />
    </div>
  </div>

  <!-- Text side -->
  <div class="md:w-3/5">
    <h3 class="text-xl font-bold text-text-primary sm:text-2xl">{title}</h3>
    <p class="mt-3 leading-relaxed text-text-secondary">{description}</p>
  </div>
</div>
