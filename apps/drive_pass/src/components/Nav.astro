---
import { getTranslations, t } from '../i18n/translations';
import type { Locale } from '../i18n/config';
import { withBase } from '../i18n/config';
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import LogoSvg from '../assets/svg/logo.svg?raw';

interface Props {
  locale: string;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const tr = getTranslations(locale as Locale);

const navLinks = [
  { key: 'nav.car',      href: withBase(`/${locale}/car`),       path: '/car' },
  { key: 'nav.moto',     href: withBase(`/${locale}/moto`),      path: '/moto' },
  { key: 'nav.examInfo', href: withBase(`/${locale}/exam-info`), path: '/exam-info' },
];

// 導向 Hero 區塊的下載按鈕區
---

<nav
  data-nav
  class="fixed top-0 z-50 w-full border-b border-transparent transition-[background-color,border-color,backdrop-filter] duration-300"
>
  <div class="mx-auto flex max-w-[1280px] items-center justify-between px-4 py-3 sm:px-6 lg:px-8">

    <!-- ── Left: Logo + Brand name ────────────────────────────────────── -->
    <a href={withBase(`/${locale}`)} class="flex items-center gap-2 shrink-0" aria-label={t(tr, 'common.a11y.home')}>
      <span class="h-8 w-8" aria-hidden="true" set:html={LogoSvg} />
      <span class="text-lg font-bold text-text-primary">駕照通</span>
    </a>

    <!-- ── Right: Desktop nav ─────────────────────────────────────────── -->
    <div class="hidden items-center gap-1 md:flex">
      {navLinks.map(({ key, href, path }) => (
        <a
          href={href}
          class:list={[
            'rounded-lg px-3 py-3 text-sm font-medium transition-colors hover:bg-bg-muted hover:text-text-primary',
            currentPath.startsWith(path) ? 'text-text-primary' : 'text-text-secondary',
          ]}
        >
          {t(tr, key)}
        </a>
      ))}

      <!-- Download CTA -->
      <a
        href={withBase(`/${locale}/#download`)}
        class="ml-2 rounded-lg bg-gradient-to-r from-car to-moto px-4 py-3 text-sm font-semibold text-white shadow-sm transition-opacity hover:opacity-90"
      >
        {t(tr, 'nav.download')}
      </a>

      <LanguageSwitcher locale={locale} currentPath={currentPath} />

      <ThemeToggle />
    </div>

    <!-- ── Right: Mobile hamburger ────────────────────────────────────── -->
    <button
      data-hamburger
      aria-label={t(tr, 'common.a11y.menuOpen')}
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="flex flex-col items-center justify-center gap-[5px] rounded-lg p-2 transition-colors hover:bg-bg-muted md:hidden"
    >
      <span class="h-[2px] w-5 rounded-full bg-text-primary transition-all"></span>
      <span class="h-[2px] w-5 rounded-full bg-text-primary transition-all"></span>
      <span class="h-[2px] w-5 rounded-full bg-text-primary transition-all"></span>
    </button>
  </div>

  <!-- ── Mobile menu ────────────────────────────────────────────────────── -->
  <div
    id="mobile-menu"
    data-mobile-menu
    class="hidden opacity-0 -translate-y-2 transform transition-all duration-200 ease-out border-t border-border-subtle bg-bg-surface/95 backdrop-blur-md md:hidden"
  >
    <div class="mx-auto max-w-[1280px] space-y-1 px-4 pb-4 pt-2 sm:px-6">
      {navLinks.map(({ key, href }) => (
        <a
          href={href}
          class="block rounded-lg px-3 py-2.5 text-sm font-medium text-text-secondary transition-colors hover:bg-bg-muted hover:text-text-primary"
        >
          {t(tr, key)}
        </a>
      ))}

      <!-- Download CTA (mobile) -->
      <a
        href={withBase(`/${locale}/#download`)}
        class="mt-2 block rounded-lg bg-gradient-to-r from-car to-moto px-3 py-2.5 text-center text-sm font-semibold text-white"
      >
        {t(tr, 'nav.download')}
      </a>

      <!-- Language switcher + theme toggle row (mobile) -->
      <div class="flex items-center justify-between pt-2">
        <LanguageSwitcher locale={locale} currentPath={currentPath} />
        <ThemeToggle />
      </div>
    </div>
  </div>
</nav>

<!-- Spacer so content doesn't hide under fixed nav -->
<div class="h-[65px]" aria-hidden="true"></div>

<style>
  /* Scrolled state injected by nav.ts */
  [data-nav].nav-scrolled {
    background-color: color-mix(in srgb, var(--color-bg-surface) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-color: var(--color-border-subtle);
  }
</style>

<script>
  import '../scripts/nav';
</script>
