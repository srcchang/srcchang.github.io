---
import { getTranslations, t } from '../i18n/translations';
import type { Locale } from '../i18n/config';
import StoreBadge from './StoreBadge.astro';

interface Props {
  locale: string;
  size?: 'sm' | 'lg';
  variant?: 'car' | 'moto';
}

const { locale, size = 'lg', variant } = Astro.props;
const tr = getTranslations(locale as Locale);
---

<div class="flex flex-col items-center gap-6 sm:flex-row sm:justify-center sm:gap-8">
  {(!variant || variant === 'car') &&
    <div class="flex flex-col items-center gap-3">
      <span class="text-sm font-medium text-text-secondary">{t(tr, 'common.downloadCar')}</span>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <StoreBadge locale={locale} platform="ios" href="https://apps.apple.com/app/id6760884522" size={size} />
        <StoreBadge locale={locale} platform="android" href="https://play.google.com/store/apps/details?id=com.src.app.drivepass.car" size={size} />
      </div>
    </div>
  }
  {(!variant || variant === 'moto') &&
    <div class="flex flex-col items-center gap-3">
      <span class="text-sm font-medium text-text-secondary">{t(tr, 'common.downloadMoto')}</span>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <StoreBadge locale={locale} platform="ios" href="https://apps.apple.com/app/id6761984973" size={size} />
        <StoreBadge locale={locale} platform="android" href="https://play.google.com/store/apps/details?id=com.src.app.drivepass.moto" size={size} />
      </div>
    </div>
  }
</div>