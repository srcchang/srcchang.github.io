---
import { getTranslations, t } from '../i18n/translations';
import type { Locale } from '../i18n/config';
import Icon from './Icon.astro';

interface Props {
  locale: string;
  size?: 'sm' | 'lg';
}

const { locale, size = 'lg' } = Astro.props;
const tr = getTranslations(locale as Locale);

const padding = size === 'lg' ? 'px-8 py-4 text-lg' : 'px-5 py-2.5 text-sm';
const iconSize = size === 'lg' ? '22' : '18';
// TODO: App 上架後把 href="#download" 換成實際 App Store / Google Play 連結
//       （目前全站無 #download 區塊，按鈕為 placeholder）
---

<div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
  <!-- Car (App Store) button -->
  <a
    href="#download"
    class:list={[
      'inline-flex items-center gap-2 rounded-xl font-semibold text-white shadow-lg transition-all',
      'bg-gradient-to-r from-car-deep to-car',
      'hover:scale-[1.02] hover:shadow-[0_8px_24px_rgba(249,115,22,0.4)]',
      padding,
    ]}
    aria-label={t(tr, 'common.downloadCar')}
  >
    <Icon name="car" size={iconSize} />
    {t(tr, 'common.downloadCar')}
  </a>

  <!-- Moto (Google Play) button -->
  <a
    href="#download"
    class:list={[
      'inline-flex items-center gap-2 rounded-xl font-semibold text-white shadow-lg transition-all',
      'bg-gradient-to-r from-moto-deep to-moto',
      'hover:scale-[1.02] hover:shadow-[0_8px_24px_rgba(139,92,246,0.4)]',
      padding,
    ]}
    aria-label={t(tr, 'common.downloadMoto')}
  >
    <Icon name="motorcycle" size={iconSize} />
    {t(tr, 'common.downloadMoto')}
  </a>
</div>
