---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import DownloadCTA from './DownloadCTA.astro';
import VehicleGlow from './VehicleGlow.astro';
import ExamComparisonTable from './ExamComparisonTable.astro';
import ScreenshotCarousel from './ScreenshotCarousel.astro';
import Icon from './Icon.astro';
import { Image } from 'astro:assets';
import CarIcon from '../assets/app-icon-car.png';
import MotoIcon from '../assets/app-icon-moto.png';
import { getTranslations, t } from '../i18n/translations';
import type { Locale } from '../i18n/config';
import { withBase } from '../i18n/config';

interface Props {
  variant: 'car' | 'moto';
  locale: string;
}

const { variant, locale } = Astro.props;
const tr = getTranslations(locale as Locale);

const isCar = variant === 'car';
const pageKey = isCar ? 'carPage' : 'motoPage';
const crossVariant = isCar ? 'moto' : 'car';
const crossPath = withBase(`/${locale}/${crossVariant}`);

const pageTitle = t(tr, `${pageKey}.title`);
const pageSubtitle = t(tr, `${pageKey}.subtitle`);

const translations = tr as Record<string, any>;
const features: { icon: string; title: string; description: string }[] = translations[pageKey]?.features ?? [];
const exclusive = translations[pageKey]?.exclusiveFeature;

// Color tokens
const borderColor = isCar ? 'border-orange-200 dark:border-orange-900' : 'border-purple-200 dark:border-purple-900';
const iconBg = isCar ? 'bg-orange-50 dark:bg-orange-950' : 'bg-purple-50 dark:bg-purple-950';
const accentText = isCar ? 'text-car' : 'text-moto';
const crossAccent = isCar ? 'text-moto hover:text-moto-deep' : 'text-car hover:text-car-deep';
const exclusiveBorder = isCar ? 'border-orange-300 dark:border-orange-800' : 'border-purple-300 dark:border-purple-800';
const exclusiveBg = isCar
  ? 'from-orange-50 to-orange-100 dark:from-orange-950/30 dark:to-orange-900/20'
  : 'from-purple-50 to-purple-100 dark:from-purple-950/30 dark:to-purple-900/20';
const ctaGradient = isCar ? 'from-car-deep to-car' : 'from-moto-deep to-moto';
const exclusiveBadgeBg = isCar ? 'bg-car' : 'bg-moto';
---
<BaseLayout
  title={`${pageTitle} — 駕照通 Drive Pass`}
  description={pageSubtitle}
  locale={locale}
  currentPath={`/${variant}`}
>
  <Nav locale={locale} currentPath={`/${variant}`} />

  <!-- Mini Hero -->
  <section class="relative overflow-hidden bg-bg-surface px-4 pb-16 pt-12 sm:px-6 lg:px-8">
    <VehicleGlow
      vehicle={variant}
      position="absolute top-0 right-0 translate-x-1/4 -translate-y-1/4"
      size="w-[400px]"
    />

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <div class="mx-auto mb-5 h-20 w-20 overflow-hidden rounded-[1.25rem] shadow-lg" aria-hidden="true">
        <Image src={isCar ? CarIcon : MotoIcon} alt="" width={160} height={160} class="h-full w-full object-cover" />
      </div>

      <h1 class="text-3xl font-bold text-text-primary sm:text-4xl">
        {pageTitle}
      </h1>
      <p class="mt-3 text-lg text-text-secondary">
        {pageSubtitle}
      </p>

      <div class="mt-8">
        <DownloadCTA locale={locale} size="lg" variant={variant} />
      </div>
    </div>
  </section>

  <!-- Cross-promotion banner -->
  <div class="border-y border-border-subtle bg-bg-muted">
    <div class="mx-auto max-w-3xl px-4 py-3 text-center sm:px-6">
      <a
        href={crossPath}
        class:list={['text-sm font-medium transition-colors', crossAccent]}
      >
        {t(tr, `${pageKey}.crossPromo`)}
      </a>
    </div>
  </div>

  <!-- Screenshot Carousel -->
  <section class="bg-bg-primary px-4 py-16 sm:px-6 lg:px-8">
    <ScreenshotCarousel variant={variant} locale={locale} />
  </section>

  <!-- Exam Comparison Table -->
  <section class="border-t border-border-subtle bg-bg-surface px-4 py-16 sm:px-6 lg:px-8">
    <ExamComparisonTable variant={variant} locale={locale} />
  </section>

  <!-- Feature Grid -->
  <section class="border-t border-border-subtle bg-bg-primary px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f, i) => (
          <div
            class:list={['rounded-2xl border bg-bg-surface p-5 transition-shadow hover:shadow-md', borderColor]}
            data-reveal
            data-reveal-delay={i * 100}
          >
            <div class:list={['mb-3 flex h-10 w-10 items-center justify-center rounded-xl', iconBg, accentText]}>
              <Icon name={f.icon} size="22" />
            </div>
            <h3 class="text-base font-semibold text-text-primary">{f.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-text-secondary">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Exclusive Feature Highlight -->
  {exclusive && (
    <section class="border-t border-border-subtle bg-bg-surface px-4 py-16 sm:px-6 lg:px-8">
      <div
        class:list={['relative mx-auto max-w-2xl overflow-hidden rounded-2xl border bg-gradient-to-br p-8', exclusiveBorder, exclusiveBg]}
        data-reveal
      >
        <div class="relative z-10">
          <span class:list={['mb-2 inline-block rounded-full px-3 py-1 text-xs font-semibold text-white', exclusiveBadgeBg]}>
            {t(tr, 'common.exclusiveFeature')}
          </span>
          <h2 class="text-xl font-bold text-text-primary sm:text-2xl">
            {exclusive.title}
          </h2>
          <p class="mt-3 text-base leading-relaxed text-text-secondary">
            {exclusive.description}
          </p>
        </div>
        <VehicleGlow
          vehicle={variant}
          position="absolute bottom-0 right-0 translate-x-1/3 translate-y-1/3"
          size="w-[200px]"
        />
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="relative overflow-hidden bg-bg-muted px-4 py-16 sm:px-6 lg:px-8" data-reveal>
    <div class="relative z-10 mx-auto max-w-xl text-center">
      <p class:list={['bg-gradient-to-r bg-clip-text text-2xl font-bold text-transparent sm:text-3xl', ctaGradient]}>
        {t(tr, 'brand.cta')}
      </p>
      <div class="mt-6">
        <DownloadCTA locale={locale} size="lg" variant={variant} />
      </div>
    </div>
  </section>

  <Footer locale={locale} />
</BaseLayout>
