---
import { locales, localeLabels } from '../i18n/config';
import type { Locale } from '../i18n/config';
import { getTranslations, t } from '../i18n/translations';

interface Props {
  locale: string;
  currentPath?: string;
}

// currentPath 省略時（如 Footer）連回各語系首頁
const { locale, currentPath = '' } = Astro.props;
const tr = getTranslations(locale as Locale);
const currentLabel = localeLabels[locale as Locale] ?? locale;
---

<details class="relative" data-language-switcher>
  <summary
    class="flex cursor-pointer list-none items-center gap-1 rounded-lg px-3 py-3 text-sm font-medium text-text-secondary transition-colors hover:bg-bg-muted hover:text-text-primary select-none"
    aria-label={t(tr, 'common.a11y.languageSelect')}
  >
    <span>{currentLabel}</span>
    <svg
      class="h-3 w-3 transition-transform duration-200"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 12 12"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M2 4l4 4 4-4" />
    </svg>
  </summary>

  <div
    class="absolute right-0 top-full z-50 mt-1 min-w-[140px] overflow-hidden rounded-xl border border-border-subtle bg-bg-surface py-1 shadow-lg"
  >
    {locales.map((loc) => (
      <a
        href={`/${loc}${currentPath}`}
        class:list={[
          'block px-4 py-2.5 text-sm transition-colors hover:bg-bg-muted',
          loc === locale
            ? 'font-semibold text-text-primary'
            : 'text-text-secondary hover:text-text-primary',
        ]}
      >
        {localeLabels[loc]}
      </a>
    ))}
  </div>
</details>

<style>
  details[open] > summary svg {
    transform: rotate(180deg);
  }

  /* Hide default disclosure marker in all browsers */
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
