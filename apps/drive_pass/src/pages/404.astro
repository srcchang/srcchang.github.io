---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { locales, localeLabels } from '../i18n/config';
import { getTranslations, t } from '../i18n/translations';
import type { Locale } from '../i18n/config';

const locale = 'zh';
const tr = getTranslations(locale as Locale);
---
<BaseLayout
  title="404 — Drive Pass"
  description={t(tr, 'notFound.title')}
  locale={locale}
  currentPath="/404"
>
  <Nav locale={locale} currentPath="/404" />

  <section class="flex min-h-[calc(100vh-8rem)] flex-col items-center justify-center px-4 py-16">
    <p class="bg-gradient-to-r from-car to-moto bg-clip-text text-[8rem] font-bold leading-none text-transparent sm:text-[10rem]">
      404
    </p>
    <h1 class="mt-4 text-2xl font-bold text-text-primary sm:text-3xl">
      {t(tr, 'notFound.title')}
    </h1>
    <p class="mt-2 text-text-secondary">
      {t(tr, 'notFound.description')}
    </p>

    <div class="mt-8 flex flex-wrap justify-center gap-3">
      {locales.map((loc) => (
        <a
          href={`/${loc}/`}
          class="rounded-lg border border-border-subtle bg-bg-surface px-4 py-2 text-sm font-medium text-text-primary transition-colors hover:border-border-strong hover:bg-bg-muted"
        >
          {localeLabels[loc]}
        </a>
      ))}
    </div>
  </section>

  <Footer locale={locale} />
</BaseLayout>
