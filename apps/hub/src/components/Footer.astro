---
import type { Locale } from '../i18n/config';
import { getTranslations, t } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = getTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="border-t border-border-subtle mt-24">
  <div class="max-w-5xl mx-auto px-4 py-10 flex flex-col sm:flex-row items-center justify-between gap-3">
    <p class="text-sm text-text-secondary">{t(tr, 'footer.tagline')}</p>
    <div class="flex items-center gap-4">
      <a href="mailto:srcchang@gmail.com" class="text-sm text-text-secondary hover:text-text-primary transition-colors no-underline">srcchang@gmail.com</a>
      <span class="text-sm text-text-tertiary">{t(tr, 'footer.copyright', { year })}</span>
    </div>
  </div>
</footer>
