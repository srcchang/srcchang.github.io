---
import type { Locale } from '../i18n/config';
import { localeLabels, locales, stripLocale, withBase } from '../i18n/config';
import { getTranslations, t } from '../i18n/translations';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const tr = getTranslations(locale);
const basePath = stripLocale(currentPath);
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/80 backdrop-blur-md border-b border-border-subtle">
  <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href={withBase(`/${locale}/`)} class="font-brand font-semibold text-lg text-text-primary no-underline">
      {t(tr, 'meta.brand')}
    </a>

    <div class="flex items-center gap-3">
      <a href={withBase(`/${locale}/#projects`)} class="text-sm text-text-secondary hover:text-text-primary transition-colors no-underline">
        {t(tr, 'nav.projects')}
      </a>

      <button id="theme-toggle" class="w-9 h-9 flex items-center justify-center rounded-lg hover:bg-bg-muted transition-colors cursor-pointer" aria-label="Toggle theme">
        <svg class="w-5 h-5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path class="dark:hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          <path class="hidden dark:block" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
      </button>

      <div class="flex items-center gap-1">
        {locales.map((l) => (
          <a
            href={withBase(`/${l}${basePath}`)}
            aria-current={l === locale ? 'true' : undefined}
            class={`text-xs px-2 py-1 rounded-md no-underline transition-colors ${l === locale ? 'text-brand font-semibold' : 'text-text-secondary hover:text-text-primary'}`}
          >
            {localeLabels[l]}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>

<script>
  import '../scripts/theme-toggle';
</script>
