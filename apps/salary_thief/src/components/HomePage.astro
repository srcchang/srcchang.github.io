---
import type { Locale } from '../i18n/config';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from './Nav.astro';
import Hero from './Hero.astro';
import TrustIndicators from './TrustIndicators.astro';
import TimerDemo from './TimerDemo.astro';
import StatsPreview from './StatsPreview.astro';
import AchievementGrid from './AchievementGrid.astro';
import CategoryCloud from './CategoryCloud.astro';
import ShareCardGallery from './ShareCardGallery.astro';
import CurrencyRow from './CurrencyRow.astro';
import FAQ from './FAQ.astro';
import BrandCTA from './BrandCTA.astro';
import Footer from './Footer.astro';
import { getTranslations, t } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = getTranslations(locale);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Salary Thief',
  operatingSystem: 'iOS, Android',
  applicationCategory: 'LifestyleApplication',
  description: t(tr, 'hero.subtitle'),
  url: 'https://srcchang.github.io/salary_thief/',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<BaseLayout
  title={`${t(tr, 'meta.brand')} — ${t(tr, 'hero.title1')}`}
  description={t(tr, 'hero.subtitle')}
  locale={locale}
  currentPath={`/${locale}/`}
  jsonLd={jsonLd}
>
  <!-- SVG filter definitions -->
  <svg class="absolute w-0 h-0" aria-hidden="true">
    <defs>
      <filter id="blur"><feGaussianBlur stdDeviation="60"/></filter>
    </defs>
  </svg>

  <Nav locale={locale} currentPath={`/${locale}/`} />
  <Hero locale={locale} />
  <TrustIndicators locale={locale} />
  <TimerDemo locale={locale} />
  <StatsPreview locale={locale} />
  <AchievementGrid locale={locale} />
  <CategoryCloud locale={locale} />
  <ShareCardGallery locale={locale} />
  <CurrencyRow locale={locale} />
  <FAQ locale={locale} />
  <BrandCTA locale={locale} />
  <Footer locale={locale} currentPath={`/${locale}/`} />
</BaseLayout>
