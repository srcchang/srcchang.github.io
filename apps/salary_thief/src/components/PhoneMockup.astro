---
interface Props {
  class?: string;
  style?: string;
  accentColor?: string;
}

const { class: className = '', style, accentColor = '#15803D' } = Astro.props;
---

<div class={`phone-frame inline-flex flex-col ${className}`} style={style}>
  <!-- Notch -->
  <div class="phone-notch"></div>
  <!-- Status bar -->
  <div class="flex justify-between px-6 pt-2 pb-1 text-caption text-text-secondary font-medium">
    <span>9:41</span>
    <span>📶 🔋</span>
  </div>
  <!-- Screen content slot -->
  <div class="flex-1 flex flex-col items-center justify-center px-4">
    <slot />
  </div>
  <!-- Home indicator -->
  <div class="flex justify-center pb-3">
    <span class="w-28 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
  </div>
</div>
