---
import type { Locale } from '../i18n/config';
import { getTranslations, t } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = getTranslations(locale);
const currency = t(tr, 'currency') as any;
---

<section class="py-12" data-reveal>
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="font-brand font-bold text-h2 mb-2">{currency.title}</h2>
    <p class="text-body-lg text-text-secondary mb-6">{currency.subtitle}</p>

    <div class="flex justify-center items-center gap-6 md:gap-10">
      <div class="text-center">
        <div class="font-brand font-bold text-2xl text-brand">NT$</div>
        <div class="text-caption text-text-tertiary mt-0.5">TWD</div>
      </div>
      <div class="w-px h-8 bg-border-subtle"></div>
      <div class="text-center">
        <div class="font-brand font-bold text-2xl text-accent">$</div>
        <div class="text-caption text-text-tertiary mt-0.5">USD</div>
      </div>
      <div class="w-px h-8 bg-border-subtle"></div>
      <div class="text-center">
        <div class="font-brand font-bold text-2xl text-blue-500">¥</div>
        <div class="text-caption text-text-tertiary mt-0.5">JPY</div>
      </div>
      <div class="w-px h-8 bg-border-subtle"></div>
      <div class="text-center">
        <div class="font-brand font-bold text-2xl text-purple-500">₩</div>
        <div class="text-caption text-text-tertiary mt-0.5">KRW</div>
      </div>
      <div class="w-px h-8 bg-border-subtle"></div>
      <div class="text-center">
        <div class="font-brand font-bold text-2xl text-red-500">¥</div>
        <div class="text-caption text-text-tertiary mt-0.5">CNY</div>
      </div>
    </div>

    <p class="text-sm text-text-tertiary mt-4">{currency.support}</p>
  </div>
</section>
