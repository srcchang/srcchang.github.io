---
import type { Locale } from '../i18n/config';
import { localeCurrencies } from '../i18n/config';
import { getTranslations, t } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = getTranslations(locale);
const { symbol } = localeCurrencies[locale];
const presets = t(tr, 'timer.presets') as { label: string; rate: number }[];
const defaultRate = t(tr, 'timer.defaultRate') as unknown as number;
const perHour = t(tr, 'timer.perHour');
---

<section id="timer-demo" class="py-16 md:py-24" data-reveal>
  <div class="max-w-4xl mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="font-brand font-bold text-h1 mb-3">{t(tr, 'timer.title')}</h2>
      <p class="text-body-lg text-text-secondary max-w-2xl mx-auto">{t(tr, 'timer.subtitle')}</p>
    </div>

    <div class="card-border p-6 md:p-8 max-w-lg mx-auto">
      <!-- Rate input -->
      <div class="mb-6">
        <label class="text-sm font-semibold text-text-primary mb-2 block">{t(tr, 'timer.rateLabel')}</label>
        <div class="flex gap-2">
          <input
            id="timer-rate"
            type="number"
            value={defaultRate}
            min="1"
            class="flex-1 px-4 py-2.5 rounded-xl border border-border-subtle bg-bg-primary text-text-primary font-brand font-semibold text-lg focus:outline-none focus:border-brand transition-colors"
          />
          <span class="flex items-center text-sm text-text-secondary font-medium">{symbol} {perHour}</span>
        </div>
        <!-- Presets -->
        <div class="flex gap-2 mt-2">
          {presets.map((p) => (
            <button data-rate={p.rate} class="text-xs px-3 py-1.5 rounded-lg border border-border-subtle text-text-secondary hover:border-brand hover:text-brand transition-colors cursor-pointer">{p.label} ({symbol}{p.rate})</button>
          ))}
        </div>
      </div>

      <!-- Timer display -->
      <div id="timer-display" class="text-center py-6">
        <div class="flex items-center justify-center gap-3 mb-2">
          <span id="timer-status" class="w-2 h-2 rounded-full bg-gray-300"></span>
          <span class="text-sm text-text-secondary font-medium">{t(tr, 'timer.timeLabel')}</span>
        </div>
        <div class="font-brand font-bold text-5xl md:text-6xl text-text-primary tabular-nums timer-time tracking-tight">
          00:00:00
        </div>
        <div class="mt-3 flex items-center justify-center gap-2">
          <span class="text-sm text-text-tertiary">≈</span>
          <span class="font-brand font-bold text-2xl text-brand timer-amount">0.00</span>
          <span class="text-sm text-text-tertiary">{symbol}</span>
        </div>
        <div class="mt-1 text-xs text-text-tertiary">{t(tr, 'timer.earnedLabel')}</div>
      </div>

      <!-- Controls -->
      <div class="flex gap-3 justify-center">
        <button id="timer-start" type="button" aria-pressed="false" data-label-start={t(tr, 'timer.start')} data-label-stop={t(tr, 'timer.stop')} class="px-6 py-2.5 rounded-xl bg-brand text-white font-semibold text-sm hover:bg-brand-deep transition-colors cursor-pointer">
          {t(tr, 'timer.start')}
        </button>
        <button id="timer-reset" class="px-6 py-2.5 rounded-xl border border-border-subtle text-text-secondary font-semibold text-sm hover:border-border-strong transition-colors cursor-pointer">
          {t(tr, 'timer.reset')}
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  import '../scripts/timer-demo';
</script>
