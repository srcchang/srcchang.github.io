---
import type { Locale } from '../i18n/config';
import { localeCurrencies } from '../i18n/config';
import { getTranslations, t } from '../i18n/translations';
import PhoneMockup from './PhoneMockup.astro';
import DownloadCTA from './DownloadCTA.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = getTranslations(locale);
const { symbol } = localeCurrencies[locale];

// Static demo shown inside the phone mockup (00:15:32 elapsed).
const demoRate = t(tr, 'hero.demo.rate') as unknown as number;
const demoElapsedSec = 932;
const demoAmount = ((demoRate * demoElapsedSec) / 3600).toFixed(2);
const demoCategories = t(tr, 'hero.demo.categories') as string[];
const catColors = ['bg-brand/10 text-brand', 'bg-accent/10 text-accent', 'bg-blue-500/10 text-blue-500'];
---

<section class="relative min-h-[90vh] flex items-center pt-24 pb-16 overflow-hidden">
  <!-- Decorative glows -->
  <div class="absolute top-0 right-0 w-[400px] h-[400px] opacity-[0.04] dark:opacity-[0.06] pointer-events-none">
    <svg viewBox="0 0 400 400" fill="#15803D">
      <circle cx="300" cy="100" r="200" filter="url(#blur)"/>
    </svg>
  </div>
  <div class="absolute bottom-0 left-0 w-[300px] h-[300px] opacity-[0.03] dark:opacity-[0.05] pointer-events-none">
    <svg viewBox="0 0 300 300" fill="#D97706">
      <path d="M50 150 Q 100 80 200 120 Q 250 60 280 150 Q 250 240 200 180 Q 100 220 50 150 Z" filter="url(#blur)"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4 w-full">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
      <!-- Text content -->
      <div class="flex-1 text-center lg:text-left" data-reveal>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-brand/10 text-brand mb-4">
          {t(tr, 'hero.badge')}
        </span>
        <h1 class="font-brand font-bold text-hero leading-tight mb-4">
          <span class="bg-gradient-to-r from-brand to-accent bg-clip-text text-transparent">{t(tr, 'hero.title1')}</span>
          <br />
          {t(tr, 'hero.title2')}
        </h1>
        <p class="text-body-lg text-text-secondary mb-8 max-w-lg mx-auto lg:mx-0">
          {t(tr, 'hero.subtitle')}
        </p>
        <div class="flex flex-wrap gap-3 justify-center lg:justify-start">
          <DownloadCTA size="lg" />
        </div>
      </div>

      <!-- Phone mockup -->
      <div class="flex-shrink-0" data-reveal data-reveal-delay="200">
        <div class="animate-float-slow">
          <PhoneMockup accentColor="#15803D">
            <!-- Timer screen inside phone -->
            <div class="text-center w-full">
              <div class="text-caption text-text-tertiary font-medium mb-1">{t(tr, 'hero.demo.timerLabel')}</div>
              <div class="font-brand font-bold text-3xl text-text-primary tabular-nums tracking-tight">
                <span>00:15:32</span>
              </div>
              <div class="mt-2 text-lg font-brand font-semibold text-brand">
                + {symbol} {demoAmount}
              </div>
              <div class="mt-1 text-caption text-text-tertiary">{t(tr, 'hero.demo.rateText')} {symbol} {demoRate}</div>
              <div class="mt-3 flex justify-center gap-2">
                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                <span class="text-caption text-text-secondary">{t(tr, 'hero.demo.status')}</span>
              </div>
              <!-- Mini category tags -->
              <div class="mt-4 flex flex-wrap justify-center gap-1">
                {demoCategories.map((cat, i) => (
                  <span class={`text-caption px-2 py-0.5 rounded-full ${catColors[i % catColors.length]}`}>{cat}</span>
                ))}
              </div>
              <!-- Mini chart -->
              <div class="mt-3 flex items-end justify-center gap-0.5 h-8">
                <span class="w-2 bg-brand/30 rounded-t"></span>
                <span class="w-2 bg-brand/40 rounded-t h-4"></span>
                <span class="w-2 bg-brand/50 rounded-t h-5"></span>
                <span class="w-2 bg-brand/60 rounded-t h-6"></span>
                <span class="w-2 bg-brand/80 rounded-t h-7"></span>
              </div>
            </div>
          </PhoneMockup>
        </div>
      </div>
    </div>
  </div>
</section>
