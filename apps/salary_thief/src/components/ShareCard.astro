---
import type { Locale } from '../i18n/config';
import { localeCurrencies } from '../i18n/config';
import { getTranslations, t } from '../i18n/translations';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type CardType = 'daily' | 'weekly' | 'monthly' | 'single' | 'achievement';

interface Props {
  type: CardType;
  locale: Locale;
  class?: string;
}

const { type, locale, class: className = '' } = Astro.props;
const tr = getTranslations(locale);
const { symbol } = localeCurrencies[locale];

// Faithful to the app's share cards (see salary_thief_flutter):
// - report/single: ShareCardFrame + bottom-corner illustration (size 100dp ≈ 28% of the 360-wide card).
// - achievement: per-category gradient, the achievement's OWN badge centered, no corner illustration.
const config: Record<
  CardType,
  { from: string; to: string; layout: 'report' | 'centered'; corner?: 'left' | 'right'; mascot?: string; badge?: string }
> = {
  daily: { from: '#2563EB', to: '#3B82F6', layout: 'report', corner: 'right', mascot: 'daily_report' },
  weekly: { from: '#7C3AED', to: '#8B5CF6', layout: 'report', corner: 'left', mascot: 'weekly_report' },
  monthly: { from: '#DC2626', to: '#EF4444', layout: 'report', corner: 'right', mascot: 'monthly_report' },
  single: { from: '#15803D', to: '#059669', layout: 'report', corner: 'right', mascot: 'single_record' },
  // first_record → "time" achievement category → violet gradient (matches the app screenshot).
  achievement: { from: '#6D28D9', to: '#7C3AED', layout: 'centered', badge: 'first_record' },
};

const c = config[type];
const card = t(tr, `shareCards.cards.${type}`) as any;
const watermark = t(tr, 'shareCards.cards.watermark');

const cornerImages = import.meta.glob<{ default: ImageMetadata }>('../assets/images/share/*.webp', { eager: true });
const badgeImages = import.meta.glob<{ default: ImageMetadata }>('../assets/images/achievements/*.webp', { eager: true });
const cornerImg = c.mascot ? cornerImages[`../assets/images/share/${c.mascot}.webp`]?.default : undefined;
const badgeImg = c.badge ? badgeImages[`../assets/images/achievements/${c.badge}.webp`]?.default : undefined;
const stats = (card.stats ?? []) as string[];

const shadow = 'text-shadow: 0 1px 4px rgba(0,0,0,0.25);';
---

<div
  class={`share-card relative overflow-hidden rounded-2xl shadow-md select-none ${className}`}
  style={`aspect-ratio: 9 / 16; background-image: linear-gradient(to bottom right, ${c.from}, ${c.to});`}
>
  {c.layout === 'report' ? (
    <>
      <div class="absolute inset-0 flex flex-col" style="padding: 7cqw;">
        <p class="font-brand font-bold text-white/85 uppercase" style={`font-size: 5.2cqw; letter-spacing: 0.12em; ${shadow}`}>{card.title}</p>
        <p class="font-brand font-extrabold text-white leading-none" style={`font-size: 17cqw; margin-top: 3cqw; ${shadow}`}>{symbol}{card.amount}</p>
        <div class="mt-auto flex flex-col" style="gap: 2.4cqw;">
          {stats.map((s) => (
            <div class="flex items-center text-white" style={`gap: 2.2cqw; ${shadow}`}>
              <span class="rounded-full bg-white/80" style="width: 2.4cqw; height: 2.4cqw;"></span>
              <span style="font-size: 5cqw;">{s}</span>
            </div>
          ))}
        </div>
      </div>
      {/* Corner illustration: app size 100dp on a 360-wide card ≈ 28%, inset above the watermark. */}
      {cornerImg && (
        <Image
          src={cornerImg}
          alt=""
          width={220}
          height={220}
          loading="lazy"
          class={`pointer-events-none absolute object-contain ${c.corner === 'left' ? 'left-[4%]' : 'right-[4%]'}`}
          style="width: 28%; bottom: 8%;"
        />
      )}
    </>
  ) : (
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center" style="padding: 7cqw;">
      <p class="font-brand font-bold text-white/85 uppercase" style={`font-size: 5.2cqw; letter-spacing: 0.16em; ${shadow}`}>{card.title}</p>
      {badgeImg && (
        <Image src={badgeImg} alt="" width={300} height={300} loading="lazy" class="object-contain" style="width: 52%; margin: 4cqw 0;" />
      )}
      <p class="font-brand font-extrabold text-white leading-tight" style={`font-size: 13cqw; ${shadow}`}>{card.name}</p>
      <p class="text-white/90" style={`font-size: 5cqw; margin-top: 2cqw; ${shadow}`}>{card.desc}</p>
      <p class="text-white/70" style={`font-size: 4.2cqw; margin-top: 3cqw; ${shadow}`}>{card.date}</p>
    </div>
  )}

  <!-- Watermark footer -->
  <div class="absolute inset-x-0 bottom-0 flex items-center justify-center text-white/70" style={`gap: 1.6cqw; padding-bottom: 4cqw; ${shadow}`}>
    <svg viewBox="0 0 24 24" fill="currentColor" style="width: 4cqw; height: 4cqw;" aria-hidden="true"><path d="M2 21h18v-2H2v2zM20 8h-2V5h2v3zm0-5H4v8a4 4 0 004 4h6a4 4 0 004-4h2a2 2 0 002-2V5a2 2 0 00-2-2z"/></svg>
    <span style="font-size: 4cqw;">{watermark}</span>
  </div>
</div>

<style>
  .share-card {
    container-type: inline-size;
  }
</style>
