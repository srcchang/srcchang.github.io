---
export interface Props {
  size?: 'sm' | 'lg';
  platform?: 'ios' | 'android' | 'both';
  class?: string;
}

const { size = 'lg', platform = 'both', class: className = '' } = Astro.props;

const iosUrl = 'https://apps.apple.com/app/id6778670803';
const androidUrl = 'https://play.google.com/store/apps/details?id=com.src.app.salarythief';

// Standard store badge height; width follows each badge's intrinsic ratio.
const badgeHeight = size === 'lg' ? 'h-12' : 'h-10';
const showIos = platform === 'both' || platform === 'ios';
const showAndroid = platform === 'both' || platform === 'android';
---

{showIos && (
  <a
    href={iosUrl}
    target="_blank"
    rel="noopener"
    aria-label="Download on the App Store"
    class={`inline-block transition-transform duration-200 hover:scale-[1.03] active:scale-[0.98] ${className}`}
  >
    <svg class={`${badgeHeight} w-auto`} viewBox="0 0 135 40" role="img" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <rect x="0.5" y="0.5" width="134" height="39" rx="6.5" fill="#000000" stroke="#A6A6A6" stroke-width="0.5" />
      <g transform="translate(20.5 8.5)">
        <path
          fill="#FFFFFF"
          d="M14.7 12.2c-.83.8-1.74.68-2.61.3-.92-.39-1.77-.4-2.74 0-1.22.52-1.86.37-2.59-.3C2.4 7.95 3.02 1.46 7.7 1.22c1.14.06 1.94.62 2.61.67 1-.2 1.96-.79 3.02-.71 1.28.1 2.24.61 2.88 1.52-2.64 1.58-2.01 5.06.4 6.03-.48 1.27-1.1 2.53-2.15 3.46zM10.2 1.18C10.07-.7 11.6-2.26 13.36-2.4c.24 2.18-1.98 3.81-3.16 3.59z"
          transform="translate(0 2.4)"
        />
      </g>
      <text x="45.5" y="15.5" fill="#FFFFFF" font-family="-apple-system, Helvetica, Arial, sans-serif" font-size="6.5">Download on the</text>
      <text x="45" y="30" fill="#FFFFFF" font-family="-apple-system, Helvetica, Arial, sans-serif" font-size="16" font-weight="600">App Store</text>
    </svg>
  </a>
)}

{showAndroid && (
  <a
    href={androidUrl}
    target="_blank"
    rel="noopener"
    aria-label="Get it on Google Play"
    class={`inline-block transition-transform duration-200 hover:scale-[1.03] active:scale-[0.98] ${className}`}
  >
    <svg class={`${badgeHeight} w-auto`} viewBox="0 0 135 40" role="img" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="gp-blue" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#00C3FF" /><stop offset="100%" stop-color="#1BE2FF" />
        </linearGradient>
        <linearGradient id="gp-green" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#00F076" /><stop offset="100%" stop-color="#00E0A0" />
        </linearGradient>
        <linearGradient id="gp-yellow" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#FFCE00" /><stop offset="100%" stop-color="#FFA000" />
        </linearGradient>
        <linearGradient id="gp-red" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#FF3A44" /><stop offset="100%" stop-color="#E11D3A" />
        </linearGradient>
      </defs>
      <rect x="0.5" y="0.5" width="134" height="39" rx="6.5" fill="#000000" stroke="#A6A6A6" stroke-width="0.5" />
      <g transform="translate(11 9.5) scale(0.875)">
        <path fill="url(#gp-blue)" d="M1.6 1.3a1 1 0 0 0-.23.7v20a1 1 0 0 0 .23.7l.07.06L12.8 11.5v-.06L1.67 1.24z" />
        <path fill="url(#gp-yellow)" d="M16.5 15.2 12.8 11.5v-.13l3.7-3.7.09.05 4.4 2.5c1.26.71 1.26 1.88 0 2.6l-4.4 2.5z" />
        <path fill="url(#gp-red)" d="M16.59 15.15 12.74 11.4 1.6 22.7a1.3 1.3 0 0 0 1.66.05l13.33-7.6" />
        <path fill="url(#gp-green)" d="M16.59 7.65 3.26.07A1.3 1.3 0 0 0 1.6.12L12.74 11.4z" />
      </g>
      <text x="42" y="15" fill="#FFFFFF" font-family="Roboto, Arial, sans-serif" font-size="6" letter-spacing="0.6">GET IT ON</text>
      <text x="41.5" y="30" fill="#FFFFFF" font-family="Roboto, Arial, sans-serif" font-size="15.5" font-weight="500">Google Play</text>
    </svg>
  </a>
)}
